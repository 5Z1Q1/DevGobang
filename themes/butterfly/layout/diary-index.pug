extends includes/layout.pug

block content
  #diary-index
    style.
      .diary-gate-form {
        max-width: 460px; margin: 8vh auto 0; padding: 2.5rem 2rem;
        background: rgba(255,255,255,0.7); border-radius: 12px;
        border: 1px solid rgba(236,72,153,0.35);
        box-shadow: 0 8px 32px rgba(236,72,153,0.15), 0 0 0 1px rgba(236,72,153,0.1);
        backdrop-filter: blur(10px); text-align: center;
        font-family: 'JetBrains Mono', 'SFMono-Regular', Consolas, monospace;
      }
      .diary-gate-form h2 { margin-bottom: 1.2rem; font-size: 1.5rem; color: #1a2238; }
      .diary-gate-form p { color: #64748b; margin-bottom: 1.5rem; font-size: 0.9rem; letter-spacing: 0.05em; }
      .diary-gate-form input {
        width: 100%; padding: 0.75rem 1rem; font-size: 1rem;
        font-family: inherit; background: rgba(245,247,251,0.8);
        border: 1px solid rgba(0,229,255,0.3); border-radius: 8px; margin-bottom: 1rem; outline: none;
        transition: all .2s; color: #1a2238;
      }
      .diary-gate-form input:focus {
        border-color: #ec4899;
        box-shadow: 0 0 0 3px rgba(236,72,153,0.15), 0 0 12px rgba(236,72,153,0.25);
      }
      .diary-gate-form button {
        width: 100%; padding: 0.75rem; font-size: 1rem; cursor: pointer; font-family: inherit;
        background: linear-gradient(90deg, #ec4899, #00e5ff); color: #fff; border: none; border-radius: 8px;
        font-weight: 600; letter-spacing: 0.06em; transition: all .2s;
      }
      .diary-gate-form button:hover {
        box-shadow: 0 0 20px rgba(236,72,153,0.4);
        transform: translateY(-1px);
      }
      .diary-list { max-width: 760px; margin: 4vh auto; padding: 0 1rem; font-family: 'JetBrains Mono', 'SFMono-Regular', Consolas, monospace; }
      .diary-list h2 { margin-bottom: 1.5rem; font-size: 1.5rem; text-align: center; color: #1a2238; }
      .diary-list h2::before { content: '> '; color: #00e5ff; }
      .diary-list ul { list-style: none; padding: 0; }
      .diary-list li {
        padding: 1.1rem 1.3rem; margin-bottom: 0.8rem;
        background: rgba(255,255,255,0.7); border-radius: 10px;
        border: 1px solid rgba(0,229,255,0.2);
        transition: all .25s; backdrop-filter: blur(8px);
      }
      .diary-list li:hover {
        transform: translateX(6px);
        border-color: rgba(0,229,255,0.55);
        box-shadow: 0 8px 24px rgba(0,229,255,0.18);
      }
      .diary-list a { text-decoration: none; color: inherit; display: block; }
      .diary-list .diary-item-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.3rem; color: #1a2238; }
      .diary-list .diary-item-date { font-size: 0.78rem; color: #0891b2; letter-spacing: 0.1em; }
      .diary-list .diary-item-desc { font-size: 0.88rem; color: #64748b; margin-top: 0.4rem; font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif; }
      .diary-list .diary-item-desc::before { content: '// '; color: #cbd5e1; }

    - const diaryPages = site.pages.filter(p => p.layout === 'diary').toArray().sort((a, b) => b.date - a.date);

    #diary-gate-form.diary-gate-form
      h2 🔒 进入日记
      p 这里是我们的私密小天地，请输入密码。
      form(onsubmit="tryUnlock(event); return false;")
        input#pwd(type="password" placeholder="请输入密码" autofocus)
        button(type="submit") 进入
      a(href="/" style="display:inline-block;margin-top:1rem;font-size:0.85rem;color:#999;text-decoration:none;") ← 返回首页

    #diary-list.diary-list(style="display:none;")
      h2 📖 我们的日记
      ul
        each p in diaryPages
          li
            a(href=url_for(p.path))
              .diary-item-title= p.title || p.slug
              .diary-item-date= p.date.format('YYYY-MM-DD')
              if p.description
                .diary-item-desc= p.description
      a(href="/" style="display:block;text-align:center;margin-top:2rem;font-size:0.85rem;color:#999;text-decoration:none;") ← 返回首页
      button#lock-again(style="display:block;margin:1rem auto 0;background:none;border:none;color:#999;font-size:0.85rem;cursor:pointer;text-decoration:underline;") 🔒 重新上锁

    script.
      (function () {
        const unlocked = sessionStorage.getItem('diaryUnlocked') === '1';
        if (unlocked) {
          document.getElementById('diary-gate-form').style.display = 'none';
          document.getElementById('diary-list').style.display = 'block';
        }
        window.tryUnlock = function (e) {
          e.preventDefault();
          const pwd = document.getElementById('pwd').value;
          if (pwd === '05151228') {
            sessionStorage.setItem('diaryUnlocked', '1');
            location.reload();
          } else {
            alert('密码不对哦~');
          }
        };
        const lockBtn = document.getElementById('lock-again');
        if (lockBtn) lockBtn.addEventListener('click', function () {
          sessionStorage.removeItem('diaryUnlocked');
          location.reload();
        });
      })();
